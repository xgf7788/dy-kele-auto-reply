# Douyin Kele Auto Reply Environment Configuration
#
# SECURITY NOTE:
# - Store cookies, phone numbers, and API keys SHOULD be provided via environment
#   variables or via the `*_from_env` fields in config/accounts.yaml.
# - NEVER commit real credentials or config/accounts.yaml to version control!

# Application
DEBUG=false
LOG_LEVEL=INFO

# Browser Settings
MAX_BROWSERS=10

# Message Queue
QUEUE_MAXSIZE=1000
HANDLER_WORKERS=5

# API Client
DEFAULT_API_TIMEOUT=60
MAX_RETRIES=3
RETRY_DELAY=5.0

# Database
DB_URL=sqlite:///storage/messages.db

# Polling Intervals (seconds)
MESSAGE_POLL_INTERVAL=0.5
STATUS_CHECK_INTERVAL=300.0

# ===== Per-Store Credentials (use `*_from_env` in accounts.yaml) =====
# Example: in accounts.yaml set `cookies_from_env: "COOKIES_STORE_001"`
#
# COOKIES_STORE_001=your_cookie_string_here
# COOKIES_STORE_002=your_cookie_string_here
# PHONE_STORE_002=YOUR_PHONE_NUMBER_HERE
# API_KEY_STORE_001=your_api_key_here
